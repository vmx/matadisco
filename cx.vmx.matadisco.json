{
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1,
  "id": "cx.vmx.matadisco",
  "defs": {
    "main": {
      "type": "record",
      "description": "A Matadisco record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "created",
          "metadata"
        ],
        "properties": {
          "created": {
            "type": "string",
            "format": "datetime",
            "description": "The time the metadata record was created"
          },
          "metadata": {
            "type": "string",
            "format": "uri",
            "description": "A URI containing metadata"
          },
          "preview": {
            "type": "object",
            "required": [
              "mimeType"
            ],
            "properties": {
              "mimeType": {
                "type": "string",
                "description": "The media type the preview has"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "The URL to the preview"
              }
            },
            "description": "Preview of the data"
          }
        }
      }
    }
  }
}